# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
DATABASE_URL=your_database_url_here

# Email Configuration (Resend)
RESEND_API_KEY=re_your_resend_api_key_here

# Cron Job Security
CRON_SECRET=your_random_secret_for_cron_auth

# App Configuration
NEXT_PUBLIC_APP_URL=https://rewardrelay.au

# Stripe Configuration
# Use sk_test_... for development/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
# Use pk_test_... for development/staging, pk_live_... for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# For local webhook testing, run: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Copy the webhook signing secret printed by the CLI (whsec_...) here
STRIPE_WEBHOOK_SECRET=whsec_...
# Create product "Reward Relay Pro" in Stripe dashboard (test mode) with two prices:
#   $9.99/month recurring → copy price ID here
#   $99/year recurring    → copy price ID here
# Subscribe webhook to: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
# Test cards: 4242... (success), 4000 0025 0000 3155 (3DS), 4000 0000 0000 9995 (fail)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Testing Configuration (Optional)
# Create this test user once in Supabase (with email confirmation)
# Tests use login-only (signup is handled by Supabase, no need to test)
TEST_EMAIL=john.g.keto+rewardrelay-test@gmail.com
TEST_PASSWORD=TestPass123!